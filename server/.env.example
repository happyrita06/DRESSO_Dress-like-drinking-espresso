PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/dresso?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
OPENROUTER_API_KEY=replace_with_your_openrouter_api_key

# Optional: restricts CORS to your deployed frontend, e.g.
# https://dresso.vercel.app — leave blank locally (defaults to allow-all).
CORS_ORIGIN=

# Optional: SMTP settings for sending email notifications when a contact/business
# inquiry is submitted. The feature works without these — the submission is
# always saved to the DB regardless; email is best-effort only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_NOTIFY_TO=
